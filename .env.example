# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# 実際の秘密鍵やURLはここには記入せず、.env.local を作成してそこに記述してください。
# ==============================================================================

# --- GOOGLE GEMINI (AI API) ---
# 有料枠（Pay-as-you-go）が有効化されたAPIキーを設定してください
GEMINI_API_KEY="your_gemini_api_key_here"

# --- LLM MODEL ROUTING (モデル選択) ---
# 開発用・高速処理用の軽量モデル名 (例: gemini-3-flash-preview)
NEXT_PUBLIC_FAST_MODEL="gemini-3-flash-preview"
# 思考プロセス・複雑なタスク用の推論モデル名 (例: gemini-3-flash-preview)
NEXT_PUBLIC_REASONING_MODEL="gemini-3-flash-preview"

# --- SUPABASE (Backend & Auth) ---
# Supabaseプロジェクトの参照URL
NEXT_PUBLIC_SUPABASE_URL="https://supabase.co"
# クライアントサイドで公開可能なアノンキー（認証などに使用）
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
